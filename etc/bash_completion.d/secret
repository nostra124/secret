# completion file for bash
_secret_complete_entries () {
	COMPREPLY=()
	local cur="${COMP_WORDS[COMP_CWORD]}"
	local commands="help version migrate-from-pass stores init ls has set get del qr edit sync-store sync-account accounts recipients"
	if [[ $COMP_CWORD -gt 1 ]]; then
		local lastarg="${COMP_WORDS[$COMP_CWORD-1]}"
		case "${COMP_WORDS[1]}" in
			has|set|get|del|qr|edit)
				COMPREPLY=($(compgen -W "$(secret ls)" ${cur}))
				;;
			gpg-encrypt|gpg-export-public-key)
				COMPREPLY=($(compgen -W "$(secret recipients)" ${cur}))
				;;
			accounts|recipients)
				COMPREPLY=($(compgen -W "$(secret stores)" ${cur}))
				;;
			sync-store)
				if [ $COMP_CWORD -gt 2 ]; then
					COMPREPLY=($(compgen -W "$(secret accounts)" ${cur}))
				else
					COMPREPLY=($(compgen -W "$(secret stores)" ${cur}))
				fi
				;;
			sync-account)
				COMPREPLY=($(compgen -W "$(secret accounts)" ${cur}))
				;;
		esac
	else
		COMPREPLY=($(compgen -W "${commands}" ${cur}))
	fi
}

complete -F _secret_complete_entries secret
