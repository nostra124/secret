#!/usr/bin/env python3
"""secret-source-keepass — a KeePass (.kdbx) source plugin for secret(1).

External source plugin implementing the secret-source protocol
(docs/sources.md): it bridges `secret import` / `secret export` to a
KeePass database via the pure-Python `pykeepass` library (no KeePassXC /
Qt required).

Protocol:
  secret-source-keepass available
  secret-source-keepass export <store> [--db PATH] [--group NAME]
  secret-source-keepass import <store> [--db PATH] [--group NAME]

Records on stdin/stdout are  <param>\\t<base64(value)>  lines.

Configuration (CLI flag overrides environment):
  --db PATH         the .kdbx file        (env KEEPASS_DB)
  --group NAME      group for the store   (default: the <store> name)
  password          env KEEPASS_PASSWORD  (or KEEPASS_PASSWORD_FILE)
  --keyfile PATH    optional key file     (env KEEPASS_KEYFILE)

Each store maps to a KeePass group; each parameter to an entry whose
title is the slash-form param id and whose password field holds the
value, so a round-trip preserves the store layout exactly.
"""
import base64
import os
import sys


def die(msg):
    sys.stderr.write("secret-source-keepass: %s\n" % msg)
    sys.exit(1)


def load_pykeepass():
    try:
        import pykeepass  # noqa: F401
        return pykeepass
    except Exception as e:  # ImportError or a broken lxml ABI
        die("pykeepass not available (%s); install python3-pykeepass" % e)


def parse_opts(argv):
    opts = {
        "db": os.environ.get("KEEPASS_DB"),
        "group": None,
        "keyfile": os.environ.get("KEEPASS_KEYFILE"),
    }
    i = 0
    while i < len(argv):
        a = argv[i]
        if a == "--db" and i + 1 < len(argv):
            opts["db"] = argv[i + 1]; i += 2
        elif a == "--group" and i + 1 < len(argv):
            opts["group"] = argv[i + 1]; i += 2
        elif a == "--keyfile" and i + 1 < len(argv):
            opts["keyfile"] = argv[i + 1]; i += 2
        else:
            die("unknown option %s" % a)
    return opts


def get_password():
    pw = os.environ.get("KEEPASS_PASSWORD")
    if pw is not None:
        return pw
    pwf = os.environ.get("KEEPASS_PASSWORD_FILE")
    if pwf:
        with open(pwf, "r") as f:
            return f.read().rstrip("\n")
    return None


def open_db(pykeepass, opts, create=False):
    if not opts["db"]:
        die("no database: pass --db PATH or set KEEPASS_DB")
    pw = get_password()
    kf = opts["keyfile"]
    if pw is None and not kf:
        die("no password: set KEEPASS_PASSWORD (or KEEPASS_PASSWORD_FILE) "
            "and/or --keyfile")
    if not os.path.exists(opts["db"]):
        if not create:
            die("database not found: %s" % opts["db"])
        return pykeepass.create_database(opts["db"], password=pw, keyfile=kf)
    return pykeepass.PyKeePass(opts["db"], password=pw, keyfile=kf)


def group_for(kp, name):
    g = kp.find_groups(name=name, first=True)
    if g is None:
        g = kp.add_group(kp.root_group, name)
    return g


def cmd_available(argv):
    # Usable if pykeepass imports. A DB/password is only needed for
    # import/export, so `available` stays cheap and side-effect free.
    try:
        import pykeepass  # noqa: F401
    except Exception:
        return 1
    return 0


def cmd_export(store, argv):
    pk = load_pykeepass()
    opts = parse_opts(argv)
    group_name = opts["group"] or store
    kp = open_db(pk, opts, create=True)
    g = group_for(kp, group_name)

    n = 0
    for line in sys.stdin:
        line = line.rstrip("\n")
        if not line or "\t" not in line:
            continue
        param, b64 = line.split("\t", 1)
        value = base64.b64decode(b64).decode("utf-8", "surrogateescape")
        entry = kp.find_entries(title=param, group=g, first=True, recursive=False)
        if entry is None:
            kp.add_entry(g, title=param, username="", password=value)
        else:
            entry.password = value
        n += 1
    kp.save()
    sys.stderr.write("keepass: exported %d parameter(s) to %s\n" % (n, opts["db"]))
    return 0


def cmd_import(store, argv):
    pk = load_pykeepass()
    opts = parse_opts(argv)
    group_name = opts["group"] or store
    kp = open_db(pk, opts, create=False)
    g = kp.find_groups(name=group_name, first=True)
    if g is None:
        return 0
    out = sys.stdout
    for entry in kp.find_entries(group=g, recursive=True):
        if entry.title is None:
            continue
        value = entry.password or ""
        b64 = base64.b64encode(
            value.encode("utf-8", "surrogateescape")).decode("ascii")
        out.write("%s\t%s\n" % (entry.title, b64))
    return 0


def main(argv):
    if not argv:
        die("usage: secret-source-keepass available|export|import <store> [opts]")
    verb = argv[0]
    if verb == "available":
        return cmd_available(argv[1:])
    if verb in ("export", "import"):
        if len(argv) < 2:
            die("%s requires a <store> argument" % verb)
        store = argv[1]
        rest = argv[2:]
        return (cmd_export if verb == "export" else cmd_import)(store, rest)
    die("unknown verb %s" % verb)


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
