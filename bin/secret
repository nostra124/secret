#!/bin/bash
#
# shellcheck disable=SC2046
# Rationale: $(...) returns whitespace-separated tokens that must be
# passed as separate arguments — multi-recipient gpg-encrypt /
# gpg-fingerprint / pass init, multi-store command:remotes, and
# multi-file `git checkout --theirs`. Quoting would change semantics.
# SC2086 (info-level — unquoted variable refs) is tracked separately
# in FEAT-213 for the deep quoting refactor.

############################################################################
# Configuration section
############################################################################

############################################################################

# This should always be the first line of code to facilitate debugging
[ -n "$SELF_DEBUG" ] && set -vx

# Per FEAT-194: VERSION read at runtime from VERSION (project root,
# canonical), with .rpk/version (dev-tree fallback for FEAT-194-era
# trees that lacked a root VERSION) and $PREFIX/share/secret/version
# (installed) as further fallbacks. The hardcoded value is used only
# if all three files are missing.
__d="$(cd "$(dirname "$0")" && pwd)"; __s="$(basename "$0")"
VERSION=$(cat "$__d/../VERSION" 2>/dev/null \
	|| cat "$__d/../.rpk/version" 2>/dev/null \
	|| cat "$__d/../share/$__s/version" 2>/dev/null \
	|| echo '0.8')
unset __d __s
SELF=$(basename "$0")

fatal() {
	echo -e "$SELF: \033[31;mfatal - $1\033[0m" >&2
	exit -1
}

debug() {
	[ -n "$SELF_DEBUG" ] && echo -e "$SELF: \033[90;mdebug - $@\033[0m" >&2
}

info() {
	[ ! -n "$SELF_QUIET" ] && echo -e "$SELF: info - \033[32;m$@\033[0m" >&2
}

warn() {
	echo -e "$SELF: warn - \033[33;1;m$@\033[0m" >&2
}

# Standard log level for a recoverable failure: the operation
# could not complete but the script continues. See skills/logging.md
# for when to use each of debug / info / warn / error. fatal() is the
# error-plus-exit convenience used by validation paths.
error() {
	echo -e "$SELF: \033[31;merror - $@\033[0m" >&2
}

# checks if a certain function exists: eg. has command update
has() {
	local KIND=$1
	local NAME=$2

	type -t "$KIND":"$NAME" | grep -q function
}

# FEAT-207 — reject path traversal in store and parameter names.
# The script accepts `secret <verb> <store>/<param>` and resolves to
# files under $SELF_CONFIG/<store>/<param>.gpg; `..` segments would
# escape the store root and read or write files anywhere reachable
# from $SELF_CONFIG (a real risk under the EUID=0 branch, where
# $SELF_CONFIG is /etc/secret/).
#
# Centralised so every parser of a store or param name calls the
# same guard. Operates AFTER the `tr` lowercasing in callers, since
# `..` is case-insensitive anyway.
validate_name() {
	local KIND=$1
	local NAME=$2
	case "$NAME" in
		*..*) fatal "$KIND name may not contain '..' (path traversal): $NAME" ;;
	esac
}

# Compute the local account identity (matches account(1) format).
# No config file needed - computed from system state.
identity() {
	local USER=$(whoami)
	local HOST=$(hostname -f | tr '[:upper:]' '[:lower:]')
	echo "$USER@$HOST"
}

# List known remote accounts from account config.
# Lists files in XDG_CONFIG_HOME/account/ssh/ removing .pub suffix.
account_list() {
	local ACCOUNT_CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/account"
	if [ -d "$ACCOUNT_CONFIG/ssh" ]; then
		ls -1 "$ACCOUNT_CONFIG/ssh" 2>/dev/null | sed 's/\.pub$//g'
	fi
}

# Check if account has a GPG key by checking config file.
account_has_gpg_key() {
	local ACCOUNT=$(echo "$1" | tr [A-Z] [a-z])
	test -z "$ACCOUNT" && return 1
	local ACCOUNT_CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/account"
	test -f "$ACCOUNT_CONFIG/gpg/${ACCOUNT}.pub"
}

# Check if account is online (SSH reachable).
account_online() {
	local ACCOUNT=$(echo "$1" | tr [A-Z] [a-z])
	test -z "$ACCOUNT" && return 1
	local ACCOUNT_HOST=${ACCOUNT#*@}
	if command -v fping >/dev/null 2>&1 && fping -4 -q "$ACCOUNT_HOST" 2>/dev/null; then
		if ssh -o "StrictHostKeyChecking=no" -o "IdentitiesOnly=yes" -o "BatchMode=yes" -o "ConnectTimeout=5" "$ACCOUNT" true 2>/dev/null; then
			return 0
		fi
	fi
	return 1
}

# Get remote URL for a store (matches account remote-url format).
account_remote_url() {
	local ACCOUNT=$1
	local PURPOSE=$2
	test -z "$ACCOUNT" && return 1
	case "$PURPOSE" in
		password-store|"")
			echo "${ACCOUNT}:~/.password-store"
			;;
		secret/*)
			echo "${ACCOUNT}:~/.config/secret/${PURPOSE#secret/}"
			;;
		*)
			echo "${ACCOUNT}:~/.config/${PURPOSE}"
			;;
	esac
}

# Export GPG public key for identity or read from account config.
gpg_export_public_key() {
	local KEY=$1
	if [ -z "$KEY" ]; then
		KEY=$(identity)
	fi
	local ACCOUNT_CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/account"
	if [ -f "$ACCOUNT_CONFIG/gpg/${KEY}.pub" ]; then
		cat "$ACCOUNT_CONFIG/gpg/${KEY}.pub"
	else
		gpg --armor --quiet --export "$KEY" 2>/dev/null
	fi
}

# Import GPG public key - save to account config and import to GPG.
gpg_import_public_key() {
	local KEY=$1
	test -z "$KEY" && fatal "please specify a key id"
	local ACCOUNT_CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/account"
	mkdir -p "$ACCOUNT_CONFIG/gpg"
	cat | tee "$ACCOUNT_CONFIG/gpg/${KEY}.pub" > /dev/null
	gpg --import "$ACCOUNT_CONFIG/gpg/${KEY}.pub" 2>/dev/null
	gpg --no-tty --quick-sign-key "$(gpg_fingerprint "$KEY")" 2>/dev/null
}

# Get GPG fingerprint(s) for key(s).
gpg_fingerprint() {
	if [ $# -eq 0 ]; then
		gpg --batch --with-colons --fingerprint --list-keys 2>/dev/null | awk -F: '
			$1 == "fpr" { fpr = $10 }
			$1 == "uid" { print uid = $10, fpr }
		' | column -t | sed 's/.*<//g' | sed 's/>//g' | sort -u | grep "^$(identity) " | awk '{print $2}'
	else
		for KEY in "$@"; do
			gpg --batch --with-colons --fingerprint --list-keys 2>/dev/null | awk -F: '
				$1 == "fpr" { fpr = $10 }
				$1 == "uid" { print uid = $10, fpr }
			' | column -t | sed 's/.*<//g' | sed 's/>//g' | sort -u | grep "^$KEY " | awk '{print $2}'
		done
	fi
}

# Encrypt stdin for given recipients (or all known accounts if none).
gpg_encrypt() {
	local TMPFILE=$(mktemp)
	local ARGS=""
	if [ $# -ne 0 ]; then
		for KEY in "$@"; do
			ARGS="$ARGS --recipient $(gpg_fingerprint "$KEY")"
		done
	else
		for ACCOUNT in $(account_list); do
			ARGS="$ARGS --recipient $(gpg_fingerprint "$ACCOUNT")"
		done
	fi
	gpg --yes --encrypt --armor --quiet --trust-model always --output "$TMPFILE" $ARGS 2>/dev/null
	local RESULT=$?
	cat "$TMPFILE"
	rm -f "$TMPFILE"
	return $RESULT
}

# Decrypt stdin using GPG.
gpg_decrypt() {
	local TMPFILE=$(mktemp)
	cat > "$TMPFILE"
	gpg --yes --decrypt --armor --quiet "$TMPFILE" 2>/dev/null
	local RESULT=$?
	rm -f "$TMPFILE"
	return $RESULT
}

# Check if a GPG identity is configured and warn if not. Commands that
# need GPG encryption/decryption call this at their entry point.
require_gpg_identity() {
	local IDENTITY
	IDENTITY=$(identity 2>/dev/null)
	if [ -z "$IDENTITY" ]; then
		warn "no GPG identity — run '$SELF setup' to configure one"
	fi
}

# We need to run getopts as soon as possible so we catch -d and other
# options that will modify our behaviour. Commands are handled at the
# end of this script.
while getopts "dqf" flag; do
	case "$flag" in
		q) SELF_QUIET=1 ;;
		d) SELF_DEBUG=1 ;;
		f) SELF_FORCE="-f" ;;
	esac
done
shift $((OPTIND - 1))

if [ -z "$SELF_PLACE" ]; then
	SELF_PLACE="user"
fi

# Read configuration and set defaults if anything's not set
: ${XDG_CONFIG_HOME:="$HOME/.config"}
: ${EUID:=$(id -u)}

if [ -z "${XDG_SECRET_STORES}" ]; then
	if [ "$EUID" -eq 0 ]; then
		SELF_CONFIG="/etc/${SELF}"
		mkdir -p "${SELF_CONFIG}"
		find "${SELF_CONFIG}" -type f -print0 | xargs -0 chmod 0644 2> /dev/null
		find "${SELF_CONFIG}" -type d -print0 | xargs -0 chmod 0755 2> /dev/null
	else
		SELF_CONFIG="${XDG_CONFIG_HOME}/${SELF}"
		mkdir -p "${SELF_CONFIG}"
	fi
else
	SELF_CONFIG="${XDG_SECRET_STORES}"
fi

[ -n "$SELF_VERBOSE" ] && set -vx

#------------------------------------------------------------------------------
command:help() {
        if [[ $# != 0 ]]; then
		if ! has command "$1"; then
			echo "'$1' is not an $SELF command"
			echo ""
			echo "please see '$SELF help'"
			return -1
		elif ! has help "$1"; then
			echo "No help found for '$1'"
			echo ""
			echo "please see '$SELF help'"
			return -2
		else
			help:"$1" "${@:2}"
			return 0
		fi
        else
                cat >&2 <<ENDHELP
usage: $SELF <options> <command>

$SELF implements a simple secret management as user and system wide.

The $SELF entries are stored as a files in a storage directory. Each $SELF
parameter is identified by an hierarchical id which is seprated by colons ':'
(e.g. host:name). A $SELF storage is looked up in the following placed, if
not explicitly selected by an option:
  * If run as root in the directory /etc/$SELF/<store>
  * If run as a normal user in the directory ${XDG_CONFIG_HOME}/${SELF}/<store>
  * The location of the user directory can be changed by the environment
    parameter \${XDG_${SELF}_STORES}

The special store "pass" is used to handle the passwords via the pass script.

options:
   -d                            enable debug mode
   -q                            enable quiet mode
   -f                            enable force mode (push and pull)

generic commands:
   help                          print this help message
   help <command>                prints command specific help.
   version                       print the version of $SELF
   identity                      show the main GPG identity
   setup                         central setup — GPG identity, git config, keys
   skills                        list available skills
   skills <skill>                print a skill definition

store management commands
   stores                        show the existing stores
   params <store>                show the parameters of the store
   init [store]                  initializes the store or bootstrap GPG identity
   pass-init                     bootstraps the pass(1) password-store
   exists <store>                check if the store <store> exists
   destroy <store>               destroys the store <store>
   clean <store>                 cleans empty parameters in store <store>

store parameter commands:
   ls [store]                    lists all parameters in store <store>
   has <store>/<param>           checks if the parameter <param> exists
   set <store>/<param>           set parameter <store>/<param> from stdin
   get <store>/<param>           get parameter <store>/<param> to stdout
   del <store>/<param>           delete param <param> in store <store>
   qr  <store>/<param>           get param <param> in store <store> as qrcode

   gen <store>/<param>           generates a random and prints to stdout
   def <store>/<param> <value>   creates a default with a default value

   ins <store>/<param>           inserts the line into param <param> from stdin
   rem <store>/<param>           removes the line into param <param> from stdin

   edit <store>/<param>          edit the param <param> in store <store>

synchronisation commands:
   remotes [stores]              lists all remotes of the stores
   pull [store] [account]        pulls the store <store> from account <account>
   push [store] [account]        pushes the store <store> to account <account>
   sync [account]                syncs all stores with the account

account encryption commands
   gpg-keys [store] [param]      lists all gpg-keys of the store or param
   add-gpg-key <store> <account> adds the gpg-key to the store
   del-gpg-key <store> <account> deletes the gpg-key from the store
   has-gpg-key <store> <account> checks if the store has the gpg-key

ENDHELP
        fi
	return 0
}

#------------------------------------------------------------------------------
help:init() {
	if [[ $# != 0 ]]; then
		fatal "unknown option $1" -1
	else
		cat >&2 <<ENDHELP

usage: $SELF init [store]

When called without a store, ensures a GPG identity exists (delegating to
\`account init\` if needed) and then re-initialises every existing store.

When called with a store, creates \`$SELF_CONFIG/<store>\` as a git repository,
imports the current account's GPG public key, and re-encrypts every parameter
for the current recipient set.

Examples:

    $SELF init                     # bootstrap GPG identity + re-init all stores
    $SELF init bitcoin              # create or re-initialise a specific store
ENDHELP
	fi
	return 0
}

#------------------------------------------------------------------------------
help:setup() {
	if [[ $# != 0 ]]; then
		fatal "unknown option $1" -1
	else
		cat >&2 <<ENDHELP

usage: $SELF setup

One-shot central setup: delegates to \`account init\` for GPG identity
(key check, backup restore, key generation), git config, SSH keys, and
agent configuration, then ensures the secret store root exists.

Run this once on a new machine before using $SELF.

Examples:

    $SELF setup
ENDHELP
	fi
	return 0
}

#------------------------------------------------------------------------------
help:identity() {
	if [[ $# != 0 ]]; then
		fatal "unknown option $1" -1
	else
		cat >&2 <<ENDHELP

usage: $SELF identity

Print the main GPG identity (\`account identity\`). Exits non-zero if
no identity has been set up yet.

Examples:

    $SELF identity
ENDHELP
	fi
	return 0
}

#------------------------------------------------------------------------------
command:version() {
	echo "$VERSION"
	return 0
}

#------------------------------------------------------------------------------
command:skills() {
	local SELF_DIR="$(cd "$(dirname "$0")" && pwd)"
	local SKILLS_DIR
	local SKILL=$(echo "$1" | tr [A-Z] [a-z])

	# Resolve the skills directory — try source tree first, then
	# installed share/data path ($PREFIX/share/secret/skills).
	for candidate in "$SELF_DIR/../skills" "$SELF_DIR/../share/secret/skills"; do
		SKILLS_DIR="$(cd "$candidate" 2>/dev/null && pwd)" && break
	done

	if [ -z "$SKILL" ]; then
		ls -1 "$SKILLS_DIR"/*.md 2>/dev/null | sed 's/.*\///g' | sed 's/\.md$//g'
	else
		if [ -f "$SKILLS_DIR/$SKILL.md" ]; then
			cat "$SKILLS_DIR/$SKILL.md"
		else
			fatal "unknown skill $SKILL"
		fi
	fi
	return 0
}

#------------------------------------------------------------------------------
command:stores() {
	[ -d "${SELF_CONFIG}" ] && ls -1 "${SELF_CONFIG}" 2> /dev/null
	[ -d "$HOME/.password-store" ] && echo "password-store"

	return 0
}

#------------------------------------------------------------------------------
command:params() {
	local STORE=$(echo "$1" | tr [A-Z] [a-z])
	test -z "$STORE" && fatal "please specify a store"
	validate_name store "$STORE"

	if [ "$STORE" = "password-store" ]; then
		if [ -d "$HOME"/.password-store ]; then
			pushd "$HOME"/.password-store > /dev/null
			# FEAT-208: match the non-password-store branch by
			# sorting and deduplicating before printing.
			find * -type f 2> /dev/null | sed s/\.gpg//g | sed 's/\//:/g' | sort -u
			popd > /dev/null
		fi
	else
		if [ -d "${SELF_CONFIG}"/"${STORE}" ]; then
			pushd "${SELF_CONFIG}"/"${STORE}" > /dev/null
			find * -type f 2> /dev/null | sed s/\.gpg//g | sed 's/\//:/g' | sort -u
			popd > /dev/null
		fi
	fi

	return 0
}

#------------------------------------------------------------------------------
#------------------------------------------------------------------------------
# FEAT-041: pass(1) password-store bootstrap (absorbed from
# crypt's pass-setup; secret-store concerns belong in secret).
command:pass-init() {
	command -v gpg  > /dev/null 2>&1 || fatal "gpg(1) missing — install your distro's 'gnupg' package" -1
	command -v pass > /dev/null 2>&1 || fatal "pass(1) missing — install your distro's 'pass' package" -1
	require_gpg_identity
	local IDENTITY=$(identity)
	test -z "$IDENTITY" && fatal "no identity — run 'secret setup' first" -1
	pass init $(gpg_fingerprint "$IDENTITY")
	pass git init
	pass git config --add receive.denyCurrentBranch ignore
	pass git reset --hard
}

#------------------------------------------------------------------------------
command:setup() {
	info "running central setup — GPG identity, git config, keys"
	
	# Bootstrap GPG identity if needed
	local IDENTITY=$(identity 2>/dev/null)
	if [ -z "$IDENTITY" ]; then
		info "no GPG identity — generating new key"
		local USER=$(whoami)
		local HOST=$(hostname -f | tr '[:upper:]' '[:lower:]')
		gpg --batch --passphrase '' --quick-generate-key "$USER@$HOST" default default 2>/dev/null
		IDENTITY=$(identity 2>/dev/null)
		test -z "$IDENTITY" && fatal "GPG identity setup failed"
	fi

	# Export public key to account config for interoperability with account(1)
	local ACCOUNT_CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/account"
	mkdir -p "$ACCOUNT_CONFIG/gpg"
	mkdir -p "$ACCOUNT_CONFIG/ssh"
	gpg_export_public_key "$IDENTITY" > "$ACCOUNT_CONFIG/gpg/${IDENTITY}.pub"

	$SELF_PREFIX mkdir -p "${SELF_CONFIG}"

	if [ -n "$IDENTITY" ]; then
		info "$SELF setup complete — identity: $IDENTITY"
	else
		fatal "GPG identity setup failed"
	fi
	return 0
}

#------------------------------------------------------------------------------
command:identity() {
	local IDENTITY
	IDENTITY=$(identity 2>/dev/null)
	if [ -z "$IDENTITY" ]; then
		fatal "no GPG identity — run '$SELF setup' first"
	fi
	echo "$IDENTITY"
	return 0
}

#------------------------------------------------------------------------------
command:init() {
	local STORE=$(echo "$1" | tr [A-Z] [a-z])

	# When called without a store, first ensure a GPG identity exists
	# (generating one if needed, matching account init behavior).
	if [ -z "$STORE" ]; then
		local IDENTITY
		IDENTITY=$(identity 2>/dev/null)
		if [ -z "$IDENTITY" ]; then
			info "no GPG identity — generating new key"
			local USER=$(whoami)
			local HOST=$(hostname -f | tr '[:upper:]' '[:lower:]')
			gpg --batch --passphrase '' --quick-generate-key "$USER@$HOST" default default 2>/dev/null
			IDENTITY=$(identity 2>/dev/null)
			test -z "$IDENTITY" && fatal "GPG identity setup failed"
			
			# Export to account config for interoperability
			local ACCOUNT_CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/account"
			mkdir -p "$ACCOUNT_CONFIG/gpg"
			gpg_export_public_key "$IDENTITY" > "$ACCOUNT_CONFIG/gpg/${IDENTITY}.pub"
		fi
	fi

	$SELF_PREFIX mkdir -p "${SELF_CONFIG}"
	if [ -z "$STORE" ]; then
		for STORE in $(command:stores); do
			command:init "$STORE"
		done
	elif [ "$STORE" = "password-store" ]; then
		if [ -d "$HOME"/.password-store ]; then
			identity | tee -a "$HOME"/.password-store/.gpg-id > /dev/null
			sort -u "$HOME"/.password-store/.gpg-id -o "$HOME"/.password-store/.gpg-id
			local OLD_GPGIDS=$(cat "$HOME"/.password-store/.gpg-id)
			local NEW_GPGIDS=$(gpg_fingerprint $(cat "$HOME"/.password-store/.gpg-id))
			if [ "$NEW_GPGIDS" != "$OLD_GPGIDS" ]; then
				pass init "$NEW_GPGIDS"
				pass git init
			fi
		else
			pass init $(gpg_fingerprint $(identity))
			pass git init
		fi
		pass git config --add receive.denyCurrentBranch ignore
		pass git reset --hard
	else
		mkdir -p "${SELF_CONFIG}"/"${STORE}"

		pushd "${SELF_CONFIG}"/"${STORE}" > /dev/null
		REPDIR=$(git rev-parse --show-toplevel 2> /dev/null)
		if [ $? -ne 0 ]; then
			git init > /dev/null
			git config --add receive.denyCurrentBranch ignore
			git reset --hard
		fi

		mkdir -p .gpg && rm -f .gpg/recipients
		gpg_export_public_key | tee .gpg/$(identity).pub > /dev/null
		for KEY in $(ls -1 .gpg | sed 's/.pub$//g'); do
			cat .gpg/"${KEY}".pub | gpg_import_public_key "${KEY}" 2> /dev/null > /dev/null
			git add -f .gpg/"${KEY}".pub
                done

		for PARAM in $(find * -type f 2> /dev/null | sed 's/.gpg$//g' 2> /dev/null); do
			if [ -s "${PARAM}".gpg ]; then
				if [ "$(command:gpg-keys "$STORE")" != "$(command:gpg-keys "$STORE" "$PARAM")" ]; then
					local TEMP=$(mktemp)
					cat "${PARAM}".gpg | gpg_decrypt | gpg_encrypt $(command:gpg-keys "$STORE") | tee "${TEMP}" > /dev/null
					test -s "${TEMP}" && mv "${TEMP}" "${PARAM}".gpg
				fi
 			else
				rm "${PARAM}"
			fi
		done
		git commit -a -m "reinitialized ${SELF}" > /dev/null
		popd > /dev/null

		if [ "$EUID" -eq 0 ]; then
			find "${SELF_CONFIG}"/"${STORE}" -type f -print0 | xargs -0 chmod 0644 2> /dev/null
			find "${SELF_CONFIG}"/"${STORE}" -type d -print0 | xargs -0 chmod 0755 2> /dev/null
		fi
	fi

	return 0
}

#------------------------------------------------------------------------------
command:exists() {
	local STORE=$(echo "$1" | tr [A-Z] [a-z])
	test -z "$STORE" && fatal "please specify a store" -1
	validate_name store "$STORE"

	if [ "$STORE" = "password-store" ]; then
		[ -d "$HOME"/.password-store ]     && return 0
	else
		[ -d "${SELF_CONFIG}/${STORE}" ] && return 0
	fi

	return 1
}

#------------------------------------------------------------------------------
command:destroy() {
	local STORE=$(echo "$1" | tr [A-Z] [a-z])
	test -z "$STORE" && fatal "please specify a store" -1
	validate_name store "$STORE"

	if [ "$STORE" = "password-store" ]; then
		[ -d "$HOME"/.password-store ]     && rm -rf "$HOME"/.password-store
	else
		[ -d "${SELF_CONFIG}/${STORE}" ] && rm -rf "${SELF_CONFIG}/${STORE}"
	fi

	return 0
}

#------------------------------------------------------------------------------
# FEAT-210: clean empty .gpg files out of a store. Advertised in
# `secret help` since the initial import but never implemented;
# Option A (implement) chosen in 0.11.0.
command:clean() {
	local STORE=$(echo "$1" | tr [A-Z] [a-z])
	test -z "$STORE" && fatal "please specify a store"
	validate_name store "$STORE"

	if [ "$STORE" = "password-store" ]; then
		[ -d "$HOME/.password-store" ] || fatal "store $STORE does not exist"
		find "$HOME/.password-store" -type f -size 0 -name '*.gpg' -delete
	else
		[ -d "${SELF_CONFIG}/${STORE}" ] || fatal "store $STORE does not exist"
		find "${SELF_CONFIG}/${STORE}" -type f -size 0 -name '*.gpg' -delete
	fi

	return 0
}

#------------------------------------------------------------------------------
command:ls() {
	# FEAT-209: case-insensitive prefix matching. The query is
	# already lowercased; use `grep -i` so a store created with
	# mixed-case directory name (e.g. Alpha/) still matches
	# `secret ls alpha`. The pre-fix behaviour silently hid such
	# stores from `ls` while `stores` showed them.
	local QUERY=$(echo "$1" | tr [A-Z] [a-z])
	for STORE in $(command:stores); do
		for PARAM in $(command:params "$STORE"); do
			echo "$STORE"/"$PARAM"
		done
	done | grep -i "^$QUERY"
}

#------------------------------------------------------------------------------
command:has() {
	local PARAM=$(echo "$1" | tr [A-Z] [a-z] | sed 's/:/\//g')
	test -z "$PARAM" && fatal "please specify a parameter" -1
	validate_name parameter "$PARAM"
	if [[ "$1" == *"/"* ]]; then
		local STORE=${PARAM%%/*}
		local PARAM=${PARAM#*/}
	else
		return 1
	fi

	if [ "$STORE" = "password-store" ]; then
		[ -e "${HOME}/.password-store/${PARAM}.gpg" ] && return 0
	else
		[ -e "${SELF_CONFIG}/${STORE}/${PARAM}.gpg" ] && return 0
	fi
	return 1
}

#------------------------------------------------------------------------------
command:set() {
	local PARAM=$(echo "$1" | tr [A-Z] [a-z] | sed 's/:/\//g')
	test -z "$PARAM" && fatal "please specify a parameter" -1
	validate_name parameter "$PARAM"
	if [[ "$1" == *"/"* ]]; then
		local STORE=${PARAM%%/*}
		local PARAM=${PARAM#*/}
	else
		fatal "please specify in the format <store>/<param>" -1
	fi

	require_gpg_identity

	if [ "$STORE" = "password-store" ]; then
		cat | pass insert -m "set ${SELF} value $PARAM" > /dev/null
	else
		[ -d "${SELF_CONFIG}/${STORE}" ] || fatal "store ${STORE} does not exist"
		pushd "${SELF_CONFIG}"/"${STORE}" > /dev/null
		local NEW=$(cat)
		if [ -e "${PARAM}.gpg" ]; then
			local OLD=$(gpg_decrypt < "${PARAM}".gpg)
			if [ "$NEW" != "$OLD" ]; then
				debug "echo \"$NEW\" | gpg_encrypt \$(command:gpg-keys \"$STORE\") | tee \"${PARAM}\".gpg"
				echo "$NEW" | gpg_encrypt $(command:gpg-keys "$STORE") | tee "${PARAM}".gpg > /dev/null
			fi
		else
			local DIR=$(dirname "${PARAM}")
			[ ! -z "$DIR" ] && mkdir -p "$DIR"
			debug "echo \"$NEW\" | gpg_encrypt \$(command:gpg-keys \"$STORE\") | tee \"${PARAM}\".gpg"
			echo "$NEW" | gpg_encrypt $(command:gpg-keys "$STORE") | tee "${PARAM}".gpg > /dev/null
		fi
	
		git add -f "${PARAM}".gpg && git commit -m "set ${SELF} value ${PARAM}" "${PARAM}".gpg > /dev/null
		popd > /dev/null
		if [ "$EUID" -eq 0 ]; then
			find "${SELF_CONFIG}"/"${STORE}" -type f -print0 | xargs -0 chmod 0644 2> /dev/null
			find "${SELF_CONFIG}"/"${STORE}" -type d -print0 | xargs -0 chmod 0755 2> /dev/null
		fi
	fi

	return 0
}

#------------------------------------------------------------------------------
command:get() {
	local PARAM=$(echo "$1" | tr [A-Z] [a-z] | sed 's/:/\//g')
	test -z "$PARAM" && fatal "please specify a parameter" -1
	validate_name parameter "$PARAM"
	if [[ "$1" == *"/"* ]]; then
		local STORE=${PARAM%%/*}
		local PARAM=${PARAM#*/}
	else
		fatal "please specify in the format <store>/<param>" -1
	fi

	require_gpg_identity

	if [ "$STORE" = "password-store" ]; then
		debug "pass ${PARAM}"
		pass "${PARAM}"
		return $?
	else
		[ -d "${SELF_CONFIG}/${STORE}" ] || fatal "store ${STORE} does not exist" -1
		if [ -e "${SELF_CONFIG}/${STORE}/${PARAM}.gpg" ]; then
			debug "gpg_decrypt < '${SELF_CONFIG}/${STORE}/${PARAM}.gpg'"
			gpg_decrypt < "${SELF_CONFIG}/${STORE}/${PARAM}.gpg"
			return $?
		else
			error "$SELF parameter ${STORE}/${PARAM} does not exist"
		fi
	fi

	return -1
}

#------------------------------------------------------------------------------
command:del() {
	local PARAM=$(echo "$1" | tr [A-Z] [a-z] | sed 's/:/\//g')
	test -z "$PARAM" && fatal "please specify a parameter" -1
	validate_name parameter "$PARAM"
	if [[ "$1" == *"/"* ]]; then
		local STORE=${PARAM%%/*}
		local PARAM=${PARAM#*/}
	else
		fatal "please specify in the format <store>/<param>"
	fi

	if [ "$STORE" = "password-store" ]; then
		pass rm -f "${PARAM}"
		return $?
	else
		[ -d "${SELF_CONFIG}/${STORE}" ] || fatal "store ${STORE} does not exist"
		if [ -f "${SELF_CONFIG}/${STORE}/${PARAM}.gpg" ]; then
			pushd "${SELF_CONFIG}"/"${STORE}" > /dev/null
			git rm "${PARAM}.gpg" && git commit -m "removed ${SELF} parameter $PARAM" "$PARAM".gpg > /dev/null
			popd > /dev/null
		fi
	fi

	return 0
}

#------------------------------------------------------------------------------
command:qr() {
	local PARAM=$(echo "$1" | tr [A-Z] [a-z] | sed 's/:/\//g')
	test -z "$PARAM" && fatal "please specify a parameter"
	validate_name parameter "$PARAM"
	if command:has "$PARAM"; then
		command:get "$PARAM" | qrencode -t utf8
		return 0
	fi
	return -1
}

#------------------------------------------------------------------------------
command:gen() {
	local PARAM=$(echo "$1" | tr [A-Z] [a-z] | sed 's/:/\//g')
	test -z "$PARAM" && fatal "please specify a parameter"
	validate_name parameter "$PARAM"
	if [[ "$1" == *"/"* ]]; then
		local STORE=${PARAM%%/*}
		local PARAM=${PARAM#*/}
	else
		fatal "please specify in the format <store>/<param>" -1
	fi

	if command:has "$STORE"/"$PARAM"; then
		command:get "$STORE"/"$PARAM"
	else 
		command:exists "$STORE" || command:init "$STORE"
		tr -dc A-Za-z0-9 </dev/urandom | head -c 33 | command:set "$STORE"/"$PARAM"
		command:get "$STORE"/"$PARAM"
	fi
}

#------------------------------------------------------------------------------
command:def() {
	local PARAM=$(echo "$1" | tr [A-Z] [a-z] | sed 's/:/\//g')
	test -z "$PARAM" && fatal "please specify a parameter"
	validate_name parameter "$PARAM"
	if [[ "$1" == *"/"* ]]; then
		local STORE=${PARAM%%/*}
		local PARAM=${PARAM#*/}
	else
		fatal "please specify in the format <store>/<param>" -1
	fi

	if command:has "$STORE"/"$PARAM"; then
		command:get "$STORE"/"$PARAM"
	else
		echo "$2" | command:set "$STORE"/"$PARAM"
		command:get "$STORE"/"$PARAM"
	fi
}

#------------------------------------------------------------------------------
command:edit() {
	local PARAM=$(echo "$1" | tr [A-Z] [a-z] | sed 's/:/\//g')
	test -z "$PARAM" && fatal "please specify a parameter"
	validate_name parameter "$PARAM"
	if [[ "$1" == *"/"* ]]; then
		local STORE=${PARAM%%/*}
		local PARAM=${PARAM#*/}
	else
		fatal "please specify in the format <store>/<param>" -1
	fi
	test -z "$EDITOR" && local EDITOR=vi
	require_gpg_identity
	if [ "$STORE" = "password-store" ]; then
		pass edit "$PARAM"
	else
		[ -d "${SELF_CONFIG}/${STORE}" ] || fatal "store ${STORE} does not exist" -1
		local TMPFILE=$(mktemp)
		pushd "${SELF_CONFIG}/${STORE}" > /dev/null
		if [ -f "${PARAM}.gpg" ]; then
			gpg_decrypt < "${PARAM}".gpg | tee "${TMPFILE}" > /dev/null
		else
			local DIR=$(dirname "${PARAM}")
			[ ! -z "$DIR" ] && mkdir -p "$DIR"
		fi
		$EDITOR "${TMPFILE}"
		gpg_encrypt $(command:gpg-keys "$STORE") < "${TMPFILE}" | tee "${PARAM}".gpg > /dev/null
		git add -f "${PARAM}".gpg > /dev/null
		git commit -m "edited ${PARAM}" "${PARAM}".gpg > /dev/null
		popd > /dev/null
		shred -f "${TMPFILE}"
	fi
	
	return 0
}

#------------------------------------------------------------------------------
command:ins() {
	# FEAT-212: hoist validation here so failures surface at the
	# outer scope instead of being absorbed by command:get/set in
	# subshells.
	local PARAM=$1
	test -z "$PARAM" && fatal "please specify a parameter"
	[[ "$PARAM" == */* ]] || fatal "please specify in the format <store>/<param>"
	validate_name parameter "$PARAM"
	local INS_VALUE OLD_VALUE
	INS_VALUE=$(cat)
	OLD_VALUE=$(command:get "$PARAM")
	echo -e "${INS_VALUE}\n${OLD_VALUE}" | sort -u | grep "\S" | command:set "$PARAM"
}

#------------------------------------------------------------------------------
command:rem() {
	# FEAT-212: see command:ins.
	local PARAM=$1
	test -z "$PARAM" && fatal "please specify a parameter"
	[[ "$PARAM" == */* ]] || fatal "please specify in the format <store>/<param>"
	validate_name parameter "$PARAM"
	local REM_VALUE OLD_VALUE
	REM_VALUE=$(cat)
	OLD_VALUE=$(command:get "$PARAM")
	echo -e "${OLD_VALUE}" | grep --invert-match "${REM_VALUE}" |
		sort -u | grep "\S" | command:set "$PARAM"
}

#------------------------------------------------------------------------------
command:remotes() {
	if [[ $# == 0 ]]; then
		# FEAT-211: guard the recursive call so an empty store list
		# does not infinite-recurse. Same pattern as command:gpg-keys
		# adopted in FEAT-200.
		local STORES="$(command:stores)"
		if [ -n "$STORES" ]; then
			command:remotes "$STORES"
		fi
		return 0
	else
		for STORE in $@; do
			if [ -d "${SELF_CONFIG}/${STORE}" ]; then
				pushd "${SELF_CONFIG}/${STORE}" > /dev/null
				git remote
				popd > /dev/null
			fi
		done | sort -u
	fi
}

#------------------------------------------------------------------------------
command:pull() {
	local STORE=$(echo "$1" | tr [A-Z] [a-z])
	local ACCOUNT=$(echo "$2" | tr [A-Z] [a-z])
	require_gpg_identity
	if [ -z "$STORE" ]; then
		for STORE in $(command:stores); do
			command:pull "$STORE"
		done
	elif [ -z "$ACCOUNT" ]; then
		for ACCOUNT in $(account_list); do
			command:pull "$STORE" "$ACCOUNT"
		done
	elif account_online "${ACCOUNT}"; then
		if [ "$STORE" = "password-store" ]; then
			[ -d "${HOME}/.password-store" ] || fatal "store ${STORE} does not exist" -1
			# FEAT-044: compute canonical SSH endpoint
			local REMOTE_URL=$(account_remote_url "$ACCOUNT" password-store)
			if $(pass git remote | grep ^"$ACCOUNT"$ > /dev/null); then
				pass git remote set-url "$ACCOUNT" "$REMOTE_URL"
			else
				pass git remote add "$ACCOUNT" "$REMOTE_URL"
			fi

			if ssh "$ACCOUNT" "$SELF" exists "$STORE"; then
				info "pulling store $STORE from account $ACCOUNT"
				BRANCH=$(pass git branch --show-current)
				info "pass git pull $SELF_FORCE --no-edit --commit --allow-unrelated-histories $ACCOUNT $BRANCH"
				pass git pull "$SELF_FORCE" --no-edit --commit --allow-unrelated-histories "$ACCOUNT" "$BRANCH"
			else
				warn "$SELF store $STORE does not exists at account $ACCOUNT"
			fi
		else
			# FEAT-044: compute canonical SSH endpoint
			local REMOTE_URL=$(account_remote_url "$ACCOUNT" "secret/${STORE}")

			[ -d "${SELF_CONFIG}/${STORE}" ] || fatal "store ${STORE} does not exist" -1
			pushd "${SELF_CONFIG}/${STORE}" > /dev/null
			if $(git remote | grep ^"$ACCOUNT"$ > /dev/null); then
				git remote set-url "$ACCOUNT" "$REMOTE_URL"
			else
				git remote add "$ACCOUNT" "$REMOTE_URL"
			fi

			if ssh "$ACCOUNT" "$SELF" exists "$STORE"; then
				info "pulling store $STORE from account $ACCOUNT"
				BRANCH=$(git branch --show-current)
				info "git pull $SELF_FORCE --no-edit --commit --allow-unrelated-histories $ACCOUNT $BRANCH"
				git pull "$SELF_FORCE" --no-edit --commit --allow-unrelated-histories "$ACCOUNT" "$BRANCH"
			else
				warn "$SELF store $STORE does not exists at account $ACCOUNT"
			fi

			# automatically resolve conflicts
			if [ ! -z "$(git diff --name-only --diff-filter=U | cat)" ]; then
				git checkout --theirs $(git diff --name-only --diff-filter=U | cat)
				warn "$SELF store $STORE - resolved merging conflicts for $(git diff --name-only --diff-filter=U | cat) by ours"
				git commit -m "resolved merging conflicts for $(git diff --name-only --diff-filter=U | cat) by ours" -a
			fi
			popd > /dev/null
		fi
	else
		warn "pulling store $STORE - account $ACCOUNT not reachable"
	fi
	return 0
}

#------------------------------------------------------------------------------
command:push() {
	local STORE=$(echo "$1" | tr [A-Z] [a-z])
	local ACCOUNT=$(echo "$2" | tr [A-Z] [a-z])
	require_gpg_identity

	if [ -z "$STORE" ]; then
		for STORE in $(command:stores); do
			command:push "$STORE"
		done
	elif [ -z "$ACCOUNT" ]; then
		for ACCOUNT in $(account_list); do
			command:push "$STORE" "$ACCOUNT"
		done
	elif account_online "${ACCOUNT}"; then
		if [ "$STORE" = "password-store" ]; then
			[ -d "${HOME}/.password-store" ] || fatal "store ${STORE} does not exist" -1
			# FEAT-044: compute canonical SSH endpoint
			local REMOTE_URL=$(account_remote_url "$ACCOUNT" password-store)
			if $(pass git remote | grep ^"$ACCOUNT"$ > /dev/null); then
				pass git remote set-url "$ACCOUNT" "$REMOTE_URL"
			else
				pass git remote add "$ACCOUNT" "$REMOTE_URL"
			fi

                        if ! ssh "$ACCOUNT" "$SELF" exists "$STORE"; then
				ssh "$ACCOUNT" "$SELF" init "$STORE"
			fi

			info "pushing store $STORE to account $ACCOUNT"
			BRANCH=$(pass git branch --show-current)
			info "pass git push $SELF_FORCE $ACCOUNT $BRANCH"
			pass git push "$SELF_FORCE" "$ACCOUNT" "$BRANCH"
		else
			# FEAT-044: compute canonical SSH endpoint
			local REMOTE_URL=$(account_remote_url "$ACCOUNT" "secret/${STORE}")

			[ -d "${SELF_CONFIG}/${STORE}" ] || fatal "store ${STORE} does not exist" -1
			pushd "${SELF_CONFIG}/${STORE}" > /dev/null
			if $(git remote | grep ^"$ACCOUNT"$ > /dev/null); then
				git remote set-url "$ACCOUNT" "$REMOTE_URL"
			else
				git remote add "$ACCOUNT" "$REMOTE_URL"
			fi

			if ! ssh "$ACCOUNT" "$SELF" exists "$STORE"; then
				ssh "$ACCOUNT" "$SELF" init "$STORE"
			fi

			info "pushing store $STORE to account $ACCOUNT"
			local BRANCH=$(git branch --show-current)
			info "git push $SELF_FORCE $ACCOUNT $BRANCH"
			git push "$SELF_FORCE" "$ACCOUNT" "$BRANCH"
			popd > /dev/null
		fi
        else
                warn "pushing store $STORE - account $ACCOUNT not reachable"
        fi
        return 0
}

#------------------------------------------------------------------------------
command:sync() {
	local ACCOUNT=$(echo "$1" | tr [A-Z] [a-z])
	require_gpg_identity
	if [ -z "$ACCOUNT" ]; then
		info "no account given - merging all accounts"
		for ACCOUNT in $(account_list); do
			command:sync "$ACCOUNT"
		done
	elif account_online "$ACCOUNT"; then
		# Remote setup is handled inline by command:pull / command:push.
		for STORE in $(ssh "$ACCOUNT" "$SELF" stores); do
			command:pull "$STORE" "$ACCOUNT"
		done

		for STORE in $(command:stores); do
			command:push "$STORE" "$ACCOUNT"
		done
	else
		warn "account $ACCOUNT not reachable"
	fi
	return 0
}

#------------------------------------------------------------------------------
command:gpg-keys() {
	local STORE=$(echo "$1" | tr [A-Z] [a-z])
	local PARAM=$(echo "$2" | tr [A-Z] [a-z] | sed 's/:/\//g')
	if [ -z "$STORE" ]; then
		# Aggregate across every store. Calling per-store avoids the
		# signature collision with `command:gpg-keys <store> <param>`.
		for STORE in $(command:stores); do
			command:gpg-keys "$STORE"
		done | sort -u
		return 0
	elif [ -z "$PARAM" ]; then
		for STORE in $@; do
			if [ "$STORE" = "password-store" ]; then
				if [ -f "$HOME"/.password-store/.gpg-id ]; then
					cat "$HOME"/.password-store/.gpg-id
				fi
				identity
			else
				if [ -d "${SELF_CONFIG}"/"${STORE}" ]; then
					pushd "${SELF_CONFIG}"/"${STORE}" > /dev/null
					ls -1 .gpg | sed 's/.pub$//g'
					popd > /dev/null
				fi
			fi
		done | sort -u
	else
		if [ -d "${SELF_CONFIG}"/"${STORE}" ]; then
			pushd "${SELF_CONFIG}"/"${STORE}" > /dev/null
			local LANG=C
			for KEYID in $(gpg --list-packets "${PARAM}".gpg 2> /dev/null | grep pubkey | sed 's/.*keyid //g'); do
				gpg --list-key "$KEYID" | grep uid | sed 's/.*<//g' | sed 's/>.*//g'
			done | sort -u
			popd > /dev/null
		fi
	fi
}

#------------------------------------------------------------------------------
command:add-gpg-key() {
	local STORE=$(echo "$1"   | tr [A-Z] [a-z]); test -z "$STORE"   && fatal "please specify a store"
	local ACCOUNT=$(echo "$2" | tr [A-Z] [a-z]); test -z "$ACCOUNT" && fatal "please specify an account"
	require_gpg_identity

	account_has_gpg_key "$ACCOUNT" || fatal "unknown account $ACCOUNT - not found in ~/.config/account/gpg/" -1
	if [ "$STORE" = "password-store" ]; then
		account_has_gpg_key "$ACCOUNT" || fatal "unknown account $ACCOUNT" -1
		info "adding gpg-key $ACCOUNT to store $STORE"
		local OLD_GPGIDS=$(cat "$HOME"/.password-store/.gpg-id)
		echo "$ACCOUNT"  | tee -a "$HOME"/.password-store/.gpg-id > /dev/null
		identity | tee -a "$HOME"/.password-store/.gpg-id > /dev/null
		sort -u "$HOME"/.password-store/.gpg-id -o "$HOME"/.password-store/.gpg-id
		local NEW_GPGIDS=$(gpg_fingerprint $(cat "$HOME"/.password-store/.gpg-id))
		if [ "$NEW_GPGIDS" != "$OLD_GPGIDS" ]; then
			command:init "$STORE"
		fi
	else
		[ -d "${SELF_CONFIG}"/"${STORE}" ] || fatal "store $STORE does not exist" 1
		account_has_gpg_key "$ACCOUNT" || fatal "unknown account $ACCOUNT" -1
		info "adding gpg-key $ACCOUNT to store $STORE"
		pushd "${SELF_CONFIG}/${STORE}" > /dev/null
		gpg_export_public_key "$ACCOUNT" > .gpg/"${ACCOUNT}".pub
		git add -f .gpg/"${ACCOUNT}".pub
		git commit -m "added gpg-key ${ACCOUNT}" -a
		command:init "$STORE"
		popd > /dev/null
	fi

	return 0
}

#------------------------------------------------------------------------------
command:del-gpg-key() {
	local STORE=$(echo "$1"   | tr [A-Z] [a-z]); test -z "$STORE"   && fatal "please specify a store"
	local ACCOUNT=$(echo "$2" | tr [A-Z] [a-z]); test -z "$ACCOUNT" && fatal "please specify an account"
	require_gpg_identity

	if [ "$STORE" = "password-store" ]; then
		local OLD_GPGIDS=$(cat "$HOME"/.password-store/.gpg-id)
		info "removing gpg-key $ACCOUNT from store $STORE"
		command:accounts "$STORE" | grep -v "${ACCOUNT}" | tee "$HOME"/.password-store/.gpg-id > /dev/null
		local NEW_GPGIDS=$(gpg_fingerprint $(cat "$HOME"/.password-store/.gpg-id))
		if [ "$NEW_GPGIDS" != "$OLD_GPGIDS" ]; then
			command:update "$STORE"
		fi
		pass git remote remove "${ACCOUNT}"
	else
		[ -d "${SELF_CONFIG}"/"${STORE}" ] || fatal "user store $STORE does not exist"
		pushd "${SELF_CONFIG}/${STORE}" > /dev/null
		if [ -f ".gpg/${ACCOUNT}.pub" ]; then
			info "removing gpg-key $ACCOUNT from store $STORE"
			git rm -f .gpg/"${ACCOUNT}".pub
			git commit -m "removed gpg-key ${ACCOUNT}" -a
			command:init "$STORE"
		fi
		popd > /dev/null
	fi
	return 0
}

#------------------------------------------------------------------------------
command:has-gpg-key() {
	local STORE=$(echo "$1" | tr [A-Z] [a-z])
	local ACCOUNT=$(echo "$2" | tr [A-Z] [a-z])
	test -z "$STORE"   && fatal "please specify a store" -1
	test -z "$ACCOUNT" && fatal "please specify an account" -1

	if [ "$STORE" = "password-store" ]; then
		cat "$HOME"/.password-store/.gpg-id | grep -q "$ACCOUNT"
	else
		test -f "${SELF_CONFIG}/${STORE}/.gpg/${ACCOUNT}.pub"
	fi
}

#------------------------------------------------------------------------------
# Command-line processing
if [[ $# == 0 ]]; then
	command:help
	exit 0
fi

if command:has "$1"; then
	command:get "$1"
	exit 0
fi

#------------------------------------------------------------------------------
# If this is a builtin command, execute it, otherwise fall through
if has command "$1"; then
        debug "executing command:$1 \"${@:2}\""
        command:"$1" "${@:2}" # array slice skipping first element
        exit $?
else
	fatal "unknown command $1"
fi
