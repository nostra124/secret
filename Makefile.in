# Makefile template for per-script repos (FEAT-191 autoconf umbrella).
#
# Substituted at `./configure` time:
#   @PREFIX@        install prefix (default $HOME/.local non-root,
#                   /usr/local root)
#   @BINDIR@        $PREFIX/bin
#   @LIBEXECDIR@    $PREFIX/libexec
#   @SYSCONFDIR@    $PREFIX/etc
#   @DATADIR@       $PREFIX/share
#   @MANDIR@        $PREFIX/share/man
#   @PACKAGE@       the package name (account / cluster / dht / …)

SHELL = /bin/bash

PACKAGE   = @PACKAGE@
PREFIX    = @PREFIX@
BINDIR    = @BINDIR@
LIBEXECDIR = @LIBEXECDIR@
SYSCONFDIR = @SYSCONFDIR@
DATADIR   = @DATADIR@
MANDIR    = @MANDIR@
LIBDIR     = $(PREFIX)/lib
INCLUDEDIR = $(PREFIX)/include

BUILD_DIR = build/$(PACKAGE)

# ---- C build (libsecstore + the secret binary) ----------------------
# secret is now a C program (lib/ + src/) linked against libsecstore.
# The binary statically embeds the library objects so it runs from the
# source tree (e.g. under bats) with no LD_LIBRARY_PATH; libsecstore.so
# / .a are also produced and installed as reusable artifacts.
CC       ?= cc
CFLAGS   ?= -O2 -std=c99 -Wall -Wextra
CPPFLAGS += -Ilib -D_GNU_SOURCE
LDFLAGS  ?=
AR       ?= ar

LIB_SRCS := $(wildcard lib/*.c)
LIB_OBJS := $(LIB_SRCS:.c=.o)
LIB_HDRS := lib/secstore.h lib/internal.h
SHLIB    := libsecstore.so
ARLIB    := libsecstore.a

.PHONY: all install uninstall check check-unit check-vectors \
        check-sit check-pit check-all lint test help package version clean \
        install-skills-user uninstall-skills-user \
        install-hooks uninstall-hooks secret lib

all: secret lib

# Build the CLI. Objects are compiled -fPIC so they double as the shared
# library; the binary links them in directly.
secret: bin/secret

lib: $(SHLIB) $(ARLIB)

lib/%.o: lib/%.c $(LIB_HDRS)
	$(CC) $(CFLAGS) $(CPPFLAGS) -fPIC -c $< -o $@

src/secret.o: src/secret.c $(LIB_HDRS)
	$(CC) $(CFLAGS) $(CPPFLAGS) -fPIC -c $< -o $@

bin/secret: $(LIB_OBJS) src/secret.o
	@mkdir -p bin
	$(CC) $(CFLAGS) $(LDFLAGS) -o $@ $(LIB_OBJS) src/secret.o

$(SHLIB): $(LIB_OBJS)
	$(CC) -shared -o $@ $(LIB_OBJS)

$(ARLIB): $(LIB_OBJS)
	$(AR) rcs $@ $(LIB_OBJS)

help:
	@echo "Targets: install, uninstall, check, lint,"
	@echo "         check-sit, check-pit, check-all,"
	@echo "         install-hooks, uninstall-hooks,"
	@echo "         install-skills-user, uninstall-skills-user,"
	@echo "         package VERSION=x.y.z, version, clean"

# Stow-based install builds a tree mirroring $PREFIX layout under
# $(BUILD_DIR), then `stow -t $(PREFIX)` symlinks it. Symmetric
# uninstall via `stow -D`.
install: all
	@command -v stow >/dev/null || { echo "stow not installed"; exit 1; }
	@mkdir -p $(BUILD_DIR)$(BINDIR) $(BUILD_DIR)$(LIBEXECDIR)/$(PACKAGE) \
	          $(BUILD_DIR)$(SYSCONFDIR)/bash_completion.d \
	          $(BUILD_DIR)$(MANDIR)/man1 \
	          $(BUILD_DIR)$(DATADIR)/doc/$(PACKAGE) \
	          $(BUILD_DIR)$(DATADIR)/$(PACKAGE) \
	          $(BUILD_DIR)$(LIBDIR) $(BUILD_DIR)$(INCLUDEDIR)
	@cp -a bin/* $(BUILD_DIR)$(BINDIR)/
	# libsecstore: the reusable C library and its public header.
	@cp -a $(SHLIB) $(ARLIB) $(BUILD_DIR)$(LIBDIR)/
	@cp -a lib/secstore.h $(BUILD_DIR)$(INCLUDEDIR)/
	@if [ -d libexec/$(PACKAGE) ]; then \
		cp -a libexec/$(PACKAGE)/* $(BUILD_DIR)$(LIBEXECDIR)/$(PACKAGE)/; \
	fi
	@if [ -d etc/bash_completion.d ]; then \
		cp -a etc/bash_completion.d/* \
		      $(BUILD_DIR)$(SYSCONFDIR)/bash_completion.d/; \
	fi
	@if [ -d share/man/man1 ]; then \
		cp -a share/man/man1/* $(BUILD_DIR)$(MANDIR)/man1/; \
	fi
	@if [ -d share/doc/$(PACKAGE) ]; then \
		cp -a share/doc/$(PACKAGE)/* \
		      $(BUILD_DIR)$(DATADIR)/doc/$(PACKAGE)/; \
	fi
	# VERSION (project-root canonical, FEAT-200-era) →
	# $DATADIR/<pkg>/version : the runtime version string the
	# binary reads. Falls back to .rpk/version (FEAT-194 legacy) if
	# VERSION is absent — e.g. on freshly cloned older trees.
	@if [ -f VERSION ]; then \
		install -m 644 VERSION $(BUILD_DIR)$(DATADIR)/$(PACKAGE)/version; \
	elif [ -f .rpk/version ]; then \
		install -m 644 .rpk/version $(BUILD_DIR)$(DATADIR)/$(PACKAGE)/version; \
	fi
	@stow -d build -t $(PREFIX) $(PACKAGE)

uninstall:
	@command -v stow >/dev/null || { echo "stow not installed"; exit 1; }
	@stow -d build -t $(PREFIX) -D $(PACKAGE) || true

# Tests
check: check-unit check-vectors

check-unit:
	@if command -v bats >/dev/null 2>&1; then \
		bats tests/unit/*.bats; \
	else echo "bats not installed; skipping"; fi

check-vectors:
	@if [ -d tests/vectors ] && command -v prove >/dev/null 2>&1; then \
		prove tests/vectors/*.t; \
	else echo "prove or tests/vectors/ not present; skipping"; fi

check-sit:
	@if ! command -v podman >/dev/null 2>&1; then \
		echo "podman not installed; soft-skipping SIT"; \
	elif [ -x tests/sit/run.sh ]; then \
		tests/sit/run.sh; \
	else \
		echo "tests/sit/run.sh not present; skipping"; \
	fi

check-pit:
	@if ! command -v podman >/dev/null 2>&1; then \
		echo "podman not installed; soft-skipping PIT"; \
	elif [ -x tests/pit/run.sh ]; then \
		tests/pit/run.sh; \
	else \
		echo "tests/pit/run.sh not present; skipping"; \
	fi

check-all: check check-sit check-pit

# bin/secret is now a compiled C program (checked by the compiler's
# -Wall -Wextra at build time); shellcheck only covers the remaining
# shell glue (hooks, completion, install/configure).
lint:
	@if command -v shellcheck >/dev/null 2>&1; then \
		shellcheck -S warning \
		  etc/hooks/* etc/bash_completion.d/* install configure \
		  $$(find libexec/$(PACKAGE) -type f 2>/dev/null) 2>/dev/null || true; \
	else echo "shellcheck not installed; skipping"; fi

test: check

# Skills installation (FEAT-192)
install-skills-user:
	@for agent_dir in \
		$$HOME/.claude/skills:claude \
		$$HOME/.config/opencode/commands:opencode; do \
		dest=$$(echo $$agent_dir | cut -d: -f1); \
		kind=$$(echo $$agent_dir | cut -d: -f2); \
		if [ -d "$$dest" ] && [ -d skills/$(PACKAGE)-* ]; then \
			for skill in skills/$(PACKAGE)-*; do \
				name=$$(basename $$skill); \
				ln -sf $(PREFIX)/share/$$kind/skills/$$name "$$dest/$$name" || true; \
			done; \
		fi; \
	done

uninstall-skills-user:
	@for skill in skills/$(PACKAGE)-*; do \
		name=$$(basename $$skill); \
		find $$HOME/.claude/skills $$HOME/.config/opencode/commands \
		  -maxdepth 1 -name $$name -type l -delete 2>/dev/null || true; \
	done

# Versioning (FEAT-194). VERSION at the project root is canonical;
# .rpk/version is kept as a mirror for FEAT-194 backwards compat. See
# skills/version.md for the release flow.
package:
	@if [ -z "$(VERSION)" ]; then \
		echo "Usage: make package VERSION=x.y.z"; exit 1; \
	fi
	@grep -qE '^[0-9]+\.[0-9]+\.[0-9]+$$' <<< "$(VERSION)" || { \
		echo "Invalid semver: $(VERSION)"; exit 1; }
	@printf '%s\t%s\n' "$(VERSION)" "$$(git rev-parse HEAD)" \
		>> .rpk/versions
	@echo "$(VERSION)" > VERSION
	@echo "$(VERSION)" > .rpk/version
	@git add VERSION .rpk/version .rpk/versions
	@git commit -m "package $(VERSION)"
	@git tag "v$(VERSION)"

# Print the currently-checked-out version. Resolution mirrors the
# fallback order in bin/secret (VERSION → .rpk/version → hardcoded).
version:
	@if [ -f VERSION ]; then \
		cat VERSION; \
	elif [ -f .rpk/version ]; then \
		cat .rpk/version; \
	else \
		echo "unknown"; \
	fi

# Git hooks. Symlink etc/hooks/* into .git/hooks/ so the versioned
# hook scripts run on push / commit. See skills/testing.md.
install-hooks:
	@if [ ! -d .git ]; then \
		echo "install-hooks: not a git repo (no .git/)"; exit 1; \
	fi
	@mkdir -p .git/hooks
	@for hook in etc/hooks/*; do \
		[ -f "$$hook" ] || continue; \
		name=$$(basename "$$hook"); \
		target=$$(pwd)/$$hook; \
		ln -sf "$$target" ".git/hooks/$$name"; \
		echo "linked .git/hooks/$$name -> $$target"; \
	done

uninstall-hooks:
	@for hook in etc/hooks/*; do \
		[ -f "$$hook" ] || continue; \
		name=$$(basename "$$hook"); \
		[ -L ".git/hooks/$$name" ] && rm ".git/hooks/$$name" \
			&& echo "removed .git/hooks/$$name" || true; \
	done

# Per FEAT-191's invariant: clean never touches installed files.
clean:
	@rm -rf build/
	@rm -f $(LIB_OBJS) src/secret.o $(SHLIB) $(ARLIB) bin/secret
