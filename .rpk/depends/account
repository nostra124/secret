#!/bin/sh
# Install dependency: account (rpk package).
set -eu

command -v account >/dev/null 2>&1 && exit 0

ACCOUNT_SRC="$HOME/.local/src/account"
if [ -d "$ACCOUNT_SRC" ]; then
	exec rpk install account
fi

echo "depends/account: 'account' not found on PATH and $ACCOUNT_SRC does not exist" >&2
exit 1
