Name:           secret
Version:        @VERSION@
Release:        1%{?dist}
Summary:        Multi-store GPG-encrypted secret manager

License:        GPL-3.0-or-later
URL:            https://github.com/nostra124/secret
Source0:        %{name}-%{version}.tar.gz

BuildRequires:  gcc
BuildRequires:  make
Requires:       git
Requires:       gnupg2
Recommends:     pass
Recommends:     qrencode
Recommends:     openssh-clients

%description
secret manages GPG-encrypted-at-rest secrets across multiple git-backed
stores, with pass(1) integration and SSH sync between peers. Each store
is a git repository and each parameter is encrypted to the store's
recipients.

%package        devel
Summary:        Development files for libsecstore
Requires:       %{name}%{?_isa} = %{version}-%{release}

%description    devel
The libsecstore static library and public header for embedding the
secret store engine in other programs.

%prep
%autosetup

%build
make -f Makefile.in all

%install
make -f Makefile.in install-dist \
    DESTDIR=%{buildroot} \
    prefix=%{_prefix} \
    libdir=%{_libdir} \
    mandir=%{_mandir} \
    sysconfdir=%{_sysconfdir}

%files
%{_bindir}/secret
%{_libdir}/libsecstore.so
%dir %{_datadir}/secret
%{_datadir}/secret/version
%{_mandir}/man1/secret.1*
%{_sysconfdir}/bash_completion.d/secret
%dir %{_libexecdir}/secret
%dir %{_libexecdir}/secret/sources
%{_libexecdir}/secret/sources/secret-source-keepass
%dir %{_datadir}/doc/secret
%doc %{_datadir}/doc/secret/README.md
%doc %{_datadir}/doc/secret/secret.md

%files devel
%{_libdir}/libsecstore.a
%{_includedir}/secstore.h

%changelog
* Thu Jun 19 2026 René Driessel <rene@driessel.de> - @VERSION@-1
- Packaged the C reimplementation (libsecstore + secret CLI).
